{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(python -m:*)",
      "Bash(pip:*)",
      "Bash(pipx:*)",
      "Bash(uv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(firebase:*)",
      "Bash(make:*)",
      "Bash(dir:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(where.exe:*)",
      "Bash(findstr:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(cd:*)",
      "Bash(set:*)",
      "Bash(env:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(tar:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(jq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(pandoc:*)",
      "Bash(powershell:*)",
      "Bash(powershell -Command:*)",
      "Bash(pwsh:*)",
      "Bash(cmd.exe:*)",
      "Bash(winget:*)",
      "Bash(ruff:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/apikeys/**)",
      "Edit(**/apikeys/**)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(echo $TOOL_INPUT | sed -n \"s/.*\\\"file_path\\\":\\\"\\([^\\\"]*\\)\\\".*/\\1/p\"); if [ -n \"$FILE\" ] && [ -f \"$FILE\" ]; then cp \"$FILE\" \"$FILE.bak\"; fi'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=\"$TOOL_INPUT\"; if echo \"$CMD\" | grep -qE \"rm -rf /|rm -rf ~|rm -rf \\\\.( |$)|chmod -R 777|:\\\\(\\\\)\\\\{|git push --force|git reset --hard|DROP TABLE|FORMAT |> *\\\\.env|>> *\\\\.env\"; then echo \"BLOCKED: 위험 명령 감지\" >&2; exit 2; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v ruff >/dev/null 2>&1 || exit 0; FILE=$(echo $TOOL_INPUT | sed -n \"s/.*\\\"file_path\\\":\\\"\\([^\\\"]*\\)\\\".*/\\1/p\"); if [[ \"$FILE\" == *.py ]] && [ -f \"$FILE\" ]; then ruff check --fix --quiet \"$FILE\" >/dev/null 2>&1; ruff format --quiet \"$FILE\" >/dev/null 2>&1; fi'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'case \"$(uname -s 2>/dev/null)\" in Darwin) afplay /System/Library/Sounds/Glass.aiff >/dev/null 2>&1 & ;; Linux) (command -v paplay >/dev/null && paplay /usr/share/sounds/freedesktop/stereo/complete.oga >/dev/null 2>&1) & ;; *) powershell -Command \"[console]::beep(800,200); [console]::beep(1000,300)\" >/dev/null 2>&1 & ;; esac; exit 0'"
          }
        ]
      }
    ]
  }
}
